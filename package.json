{
  "name": "babbel-api",
  "version": "1.0.0",
  "description": "HTTP API for generating audio news bulletins for radio automation systems",
  "main": "babbel",
  "scripts": {
    "test": "jest --config tests/jest.config.js",
    "test:watch": "jest --config tests/jest.config.js --watch",
    "test:auth": "jest --config tests/jest.config.js --testPathPatterns=auth/auth",
    "test:permissions": "jest --config tests/jest.config.js --testPathPatterns=auth/permissions",
    "test:lockout": "jest --config tests/jest.config.js --testPathPatterns=auth/lockout",
    "test:stations": "jest --config tests/jest.config.js --testPathPatterns=stations/stations",
    "test:voices": "jest --config tests/jest.config.js --testPathPatterns=voices/voices",
    "test:station-voices": "jest --config tests/jest.config.js --testPathPatterns=station-voices/station-voices",
    "test:stories": "jest --config tests/jest.config.js --testPathPatterns=stories/stories",
    "test:tts": "jest --config tests/jest.config.js --testPathPatterns=tts/tts",
    "test:settings": "jest --config tests/jest.config.js --testPathPatterns=settings/tts-settings",
    "test:bulletins": "jest --config tests/jest.config.js --testPathPatterns=bulletins/bulletins",
    "test:cleanup": "jest --config tests/jest.config.js --testPathPatterns=bulletins/bulletin-cleanup",
    "test:automation": "jest --config tests/jest.config.js --testPathPatterns=automation/automation",
    "test:users": "jest --config tests/jest.config.js --testPathPatterns=users/users",
    "test:validation": "jest --config tests/jest.config.js --testPathPatterns=validation/validation",
    "test:contract": "jest --config tests/jest.config.js --testPathPatterns=openapi/openapi-contract",
    "test:unit": "jest --config tests/jest.unit.config.js",
    "test:contract:unit": "jest --config tests/jest.unit.config.js --testPathPatterns=lib/OpenApiContractValidator",
    "lint:openapi": "redocly lint openapi.yaml",
    "test:quick": "JEST_SKIP_DOCKER=true jest --config tests/jest.config.js",
    "test:no-docker": "npm run test:quick --"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@redocly/cli": "^2.39.0",
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "axios": "^1.18.1",
    "axios-cookiejar-support": "^7.0.0",
    "form-data": "^4.0.6",
    "jest": "^30.4.2",
    "tough-cookie": "^6.0.2",
    "yaml": "^2.9.0"
  },
  "keywords": [
    "radio",
    "audio",
    "news",
    "api",
    "automation",
    "broadcasting"
  ],
  "author": "ZuidWest FM",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oszuidwest/zwfm-babbel.git"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
